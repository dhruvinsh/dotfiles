{{- $paths := list }}
{{- $homeDir := .chezmoi.homeDir }}
{{- range $_, $relPath := list "bin" "go/bin" ".cargo/bin" ".local/bin" ".local/share/bob/nvim-bin" }}
{{-    $path := joinPath $homeDir $relPath }}
{{-   if stat $path }}
{{-     $paths = mustAppend $paths $path }}
{{-   end }}
{{- end }}
{{- if $paths }}
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{- end }}

fpath=(~/.zsh/completions $fpath)

# Enable persistent history
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_SAVE_NO_DUPS
setopt INC_APPEND_HISTORY

# Configure the push directory stack (most people don't need this)
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT

# Emacs keybindings
bindkey -e

# Move to directories without cd
setopt autocd

# Initialize completion
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C  # skip audit, use cached dump
fi

# The most important aliases ever (the only thing I borrowed from OMZ)
alias l='ls -lah'
alias la='ls -lAh'
alias ll='ls -lh'
alias ls='ls -G'
alias lsa='ls -lah'
alias vim=nvim
alias lg=lazygit

# Set up fzf key bindings and fuzzy completion
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS=" \
  --highlight-line \
  --info=inline-right \
  --ansi \
  --layout=reverse \
  --border=none \
  --multi \
  --color=bg+:-1 \
  --color=bg:-1 \
  --color=fg+:{{ .colorScheme.text | quote }} \
  --color=fg:{{ .colorScheme.text | quote }} \
  --color=header:{{ .colorScheme.red | quote }} \
  --color=hl+:{{ .colorScheme.red | quote }} \
  --color=hl:{{ .colorScheme.red | quote }} \
  --color=info:{{ .colorScheme.mauve | quote }} \
  --color=marker:{{ .colorScheme.lavender | quote }} \
  --color=pointer:{{ .colorScheme.rosewater | quote }} \
  --color=prompt:{{ .colorScheme.mauve | quote }} \
  --color=selected-bg:{{ .colorScheme.surface1 | quote }} \
  --color=spinner:{{ .colorScheme.rosewater | quote }} \
"
eval "$(fzf --zsh)"

# Set up zoxide to move between folders efficiently
eval "$(zoxide init zsh)"

# Set up the Starship prompt
export STARSHIP_CONFIG=~/.config/starship/starship.toml
eval "$(starship init zsh)"

# Atuin Setup
eval "$(atuin init zsh)"

# mise-en-place setup (replaces volta, pyenv)
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/mise activate zsh)"
{{ else -}}
eval "$(~/.local/bin/mise activate zsh)"
{{- end }}

export NVIM_COLORSCHEME={{ .colorScheme.name }}
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR='nvim'
{{- if eq .chezmoi.os "darwin" }}
export HOMEBREW_NO_AUTO_UPDATE=1
{{- end }}
{{- if .wsl }}
export DISPLAY=:0
# https://github.com/microsoft/wslg/wiki/GPU-selection-in-WSLg
export MESA_D3D12_DEFAULT_ADAPTER_NAME=NVIDIA
export PATH=/usr/lib/wsl/lib:$PATH

# In wsl some annoying windows paths get added, some are useful and some aren't
# let's remove the annoying ones
export PATH=$(echo $PATH | tr ":" "\n" | rg -vi appdata | paste -sd':' -)
{{- end}}

{{ includeTemplate ".chezmoitemplates/encryption/jira" | decrypt }}

##################################################################
# User functions
csv() {
  uvx --with openpyxl visidata "$@"
}

llm() {
  command llm "$@" | streamdown
}

f() {
  local cmd=()
  local fzf_args=()
  local found_sep=0
  for arg in "$@"; do
    if [ "$arg" = "--" ]; then
      found_sep=1
      continue
    fi
    if [ $found_sep -eq 0 ]; then
      cmd+=("$arg")
    else
      fzf_args+=("$arg")
    fi
  done
  "${cmd[@]}" | fzf "${fzf_args[@]}"
}

# tmux selector powered by fzf
t() {
  if [ $# -eq 0 ]; then
    # No args: pick a session via fzf
    local session
    session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | fzf --prompt='Select tmux session: ') || return
    tmux attach-session -t "$session"
  else
    local session="$1"
    if tmux has-session -t="$session" 2>/dev/null; then
      tmux attach-session -t "$session"
    else
      tmux new-session -s "$session"
    fi
  fi
}

{{ $nvidia := output "sh" "-c" "lspci -k 2>/dev/null | grep -iq nvidia && echo 'yes' || echo 'no'" | trim -}}
{{ if eq $nvidia "yes" -}}
cuda_switch() {
  local cuda_root="/usr/local"
  local versions=($(find $cuda_root -maxdepth 1 ! -type l -name '*cuda*' | awk -F'cuda-' '/cuda-/ {print $2}' | sort))
  local target="$1"

  # Validate argument presence and format
  if [[ -z "$target" ]]; then
      echo "Usage: cuda_switch <${versions[*]}>"
      return 1
  fi

  if [[ ! "$target" =~ ^[0-9]+\.[0-9]+$ ]]; then
      echo "Error: Invalid version format '${target}'. Expected format: X.Y"
      return 1
  fi

  # Check if requested version exists
  if (( ! ${versions[(Ie)$target]} )); then
      echo "Usage: cuda_switch <${versions[*]}>"
      return 1
  fi

  # Remove any existing cuda entries from PATH (only cuda-X.Y/bin style paths)
  PATH=$(echo "$PATH" | tr ':' '\n' | grep -Ev "^${cuda_root}/cuda(-[0-9.]+)?/" | grep -v '^$' | tr '\n' ':' | sed 's/:$//')
  # Remove any existing cuda entries from LD_LIBRARY_PATH
  LD_LIBRARY_PATH=$(echo "${LD_LIBRARY_PATH:-}" | tr ':' '\n' | grep -Ev "^${cuda_root}/cuda(-[0-9.]+)?/" | grep -v '^$' | tr '\n' ':' | sed 's/:$//')

  export CUDA_HOME="${cuda_root}/cuda-${target}"
  export PATH="${CUDA_HOME}/bin:$PATH"
  export LD_LIBRARY_PATH="${CUDA_HOME}/lib64${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"

  # For convenience, you can also make /usr/local/cuda point to the selected version (optional, needs sudo)
  # sudo ln -sfn "${CUDA_HOME}" "${cuda_root}/cuda"

  echo "Switched to CUDA ${target}. (PATH updated, LD_LIBRARY_PATH set)"
}
{{ end -}}

