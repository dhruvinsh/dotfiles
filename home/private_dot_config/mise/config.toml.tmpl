[tools]
# Editor
neovim                                                = "nightly"

# Node and JavaScript related stuff
bun                                                   = "latest"
node                                                  = { version = "lts", postinstall = "corepack enable"}
zig                                                   = "latest"

# Node based tools and package managers
"npm:pnpm"                                            = "latest"
"npm:@agentclientprotocol/claude-agent-acp"           = "latest"
"npm:@google/gemini-cli"                              = "latest"
"npm:@qwen-code/qwen-code"                            = "latest"
"npm:ccusage"                                         = "latest"
"npm:defuddle"                                        = "latest"
"npm:license-checker"                                 = "latest"
"npm:mcp-hub"                                         = "latest"
"npm:neovim"                                          = "latest"
"npm:pyright"                                         = "latest"
"npm:typescript"                                      = "latest"
"npm:typescript-language-server"                      = "latest"
"npm:vite"                                            = "latest"
"npm:yarn"                                            = "latest"
codex                                                 = "latest"
copilot                                               = "latest"
pi                                                    = "latest"
tree-sitter                                           = "latest"
viteplus                                              = "latest"
{{ if ne .chezmoi.os "windows" -}}
opencode                                              = "latest"
{{ end -}}

# Python based tools
"pipx:httpie"                                         = "latest"
"pipx:jupyterlab"                                     = "latest"
"pipx:keymap-drawer"                                  = "latest"
"pipx:llm"                                            = "latest"
"pipx:pipenv"                                         = "latest"
"pipx:poetry"                                         = "latest"
"pipx:pyrefly"                                        = "latest"
"pipx:streamdown"                                     = "latest"

# LSP, Lint tools for neovim
"cargo:https://github.com/feel-ix-343/markdown-oxide" = { version = "tag:{{ (gitHubLatestTag "feel-ix-343/markdown-oxide").Name }}", bin = "markdown-oxide" }
"cargo:selene"                                        = "latest"
"go:github.com/owenrumney/make-ls/cmd/make-ls"        = "latest"
"go:golang.org/x/tools/cmd/goimports"                 = "latest"
"go:golang.org/x/tools/gopls"                         = "latest"
"npm:@vtsls/language-server"                          = "latest"
"npm:bash-language-server"                            = "latest"
"npm:vscode-json-languageserver"                      = "latest"
"npm:vscode-langservers-extracted"                    = "latest"
"npm:yaml-language-server"                            = "latest"
"pipx:basedpyright"                                   = "latest"
"pipx:codespell"                                      = "latest"
ast-grep                                              = "latest"
checkmake                                             = "latest"
dprint                                                = "latest"
gofumpt                                               = "latest"
golangci-lint                                         = "latest"
harper-ls                                             = "latest"
lua-language-server                                   = "latest"
markdownlint-cli2                                     = "latest"
prek                                                  = "latest"
prettier                                              = "latest"
ruff                                                  = "latest"
shellcheck                                            = "latest"
shfmt                                                 = "latest"
stylua                                                = "latest"
taplo                                                 = "latest"
ty                                                    = "latest"
vale                                                  = "latest"

# Mise related stuff
usage                                                 = "latest"

# Python related stuff
# NOTE: I have to strip "patch" version because windows do not always have update python version
# mise ERROR failed to install core:python@3.11.13
# mise ERROR no precompiled python found for core:python@3.11.13 on x86_64-pc-windows-msvc-shared
python                                                = {{ regexReplaceAll "\\.[0-9]+$" .pythonVersion "" | quote }}
uv                                                    = "latest"

[settings]
experimental = true
idiomatic_version_file_enable_tools = ["node", "python"]
minimum_release_age = "3d"
pipx.uvx = true
python.uv_venv_auto = false
