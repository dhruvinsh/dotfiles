#!/bin/bash
# vim: set expandtab ts=4 sw=4 ft=sh:

# {{ if stat (joinPath .chezmoi.homeDir ".zsh" "completions") }}
TARGET="$HOME"/.zsh/completions/_semver
echo "Setting up zsh completion for semver..."
echo "" > "$TARGET"
tee "$TARGET" >/dev/null << 'EOF'
#compdef semver

# zsh completion for the semver script
_semver() {
    _arguments -s -S \
        '1:action:(major minor patch)' \
        '(-f --file)--file=[Path to the version file]:file:_files' \
        '(-f --file)-f=[Path to the version file]:file:_files' \
        '--no-git[Skip creating a git tag]' \
        '--force-file[Force using the version file even in npm/uv projects]'
}

_semver
EOF

TARGET="$HOME"/.zsh/completions/_t
echo "Setting up zsh completion for t..."
echo "" > "$TARGET"
tee "$TARGET" > /dev/null << 'EOF'
#compdef t

# Tab completion for `t` using existing tmux session names
_t_complete() {
  local -a sessions
  sessions=(${(f)"$(tmux list-sessions -F '#{session_name}' 2>/dev/null)"})
  compadd -- $sessions
}
compdef _t_complete t
EOF

# {{ end }}
