#!/usr/bin/env bash
# vim: set expandtab ft=bash ts=4 tw=4:
set -euo pipefail

# {{ template "scripts/download_helpers.sh" . }}
# {{ template "scripts/service_helpers.sh" . }}

packages=(
    adw-gtk-theme
    emacs-wayland
    gwenview
    nvidia-container-toolkit
    nwg-look
    obsidian
    syncthing
    wine
    zed
)

aur_pkgs=(
    bibata-cursor-theme-bin
    brave-bin
    feishin-bin
    flat-remix
    flat-remix-gtk
    localsend-bin
    visual-studio-code-bin
)
install_packages_from_arrays

system_services=()
user_services=(
    syncthing.service
)
enable_services_from_arrays

# Ensure timezone can be updated without needing to sudo
sudo tee /etc/sudoers.d/10-tzupdate >/dev/null <<EOF
%wheel ALL=(root) NOPASSWD: /usr/bin/tzupdate, /usr/bin/timedatectl
EOF
sudo chmod 0440 /etc/sudoers.d/10-tzupdate
